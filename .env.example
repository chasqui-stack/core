# App
APP_NAME=Chasqui Core
DEBUG=true

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=chasqui

# JWT (admin authentication)
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5191,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Internal API key — shared secret the WhatsApp gateway uses to call /ingest
# INTERNAL_API_KEY=your_api_key_here

# LLM (configurable provider via LangChain)
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
EMBEDDING_MODEL=text-embedding-004
