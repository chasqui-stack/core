# Kamal secrets — copy to .kamal/secrets (gitignored) and fill in.
#   cp .kamal/secrets.example .kamal/secrets
# Values may also reference your environment or a password manager, e.g.:
#   DOCKER_REGISTRY_PASSWORD=$DOCKER_REGISTRY_PASSWORD
# Docs: https://kamal-deploy.org/docs/commands/secrets/

DOCKER_REGISTRY_PASSWORD=

# --- Database (the pgvector accessory reads POSTGRES_PASSWORD too) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=chasqui

# --- Admin JWT (generate with: openssl rand -hex 32) ---
JWT_SECRET_KEY=

# --- Gateway -> core shared secret (SAME value as the gateway's) ---
INTERNAL_API_KEY=

# --- LLM / embeddings (match LLM_PROVIDER/EMBEDDING_PROVIDER in deploy.yml) ---
GOOGLE_API_KEY=

# --- Media storage (ADR-003, OPTIONAL — uncomment in config/deploy.yml too) ---
# STORAGE_ENDPOINT_URL=
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_REGION=
