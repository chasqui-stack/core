# App
APP_NAME=Chasqui Core
DEBUG=true

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=chasqui

# JWT (admin authentication)
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5191,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Internal API key — shared secret the WhatsApp gateway uses to call /ingest
# INTERNAL_API_KEY=your_api_key_here

# LLM — provider/model swappable via init_chat_model (app/core/llm.py)
#   google + gemini-2.5-flash (stable, multimodal) | gemini-3-flash-preview
#   anthropic + claude-sonnet-4-6 | openai + gpt-5-mini
#   openrouter + vendor/model | ollama + llama3.3 (local)
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.7
GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=            # any OpenAI-compatible server
# OPENROUTER_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# Modality overrides for models the capability registry doesn't know
# (app/core/llm_capabilities.py). Unset = auto-detect by model name.
# LLM_SUPPORTS_VISION=true
# LLM_SUPPORTS_AUDIO=false

# Embeddings (memory + FAQ-RAG) — provider-swappable like the LLM.
# The dimension comes from EMBEDDING_DIM below (default 768 — quality ~equal,
# 4x cheaper than 3072). Providers and how they honor it:
#   google + gemini-embedding-001 (Matryoshka -> 768 requested)
#   openai + text-embedding-3-small (dimensions=768 requested)
#   ollama + nomic-embed-text (768 native, local)
# Switching providers requires re-embedding existing rows.
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-001
# Vector width — PROVISION-TIME: baked into the schema on first migrate.
# Changing it later = column migration + re-embed. <=2000 HNSW-indexable as
# vector; 3072 (gemini native) uses halfvec index; >4000 exact scan only.
EMBEDDING_DIM=768

# Agent turn
HISTORY_LIMIT=20
